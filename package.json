{
  "name": "design-patterns",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "server",
    "frontend",
    "patterns/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:frontend": "npm run dev --workspace=frontend",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
